# App Configuration
SECRET_KEY=your_secret_key_here

# Database Configuration
# Use local SQLite db during development: sqlite:///database.db
# Use PostgreSQL/MySQL for production
DATABASE_URL=sqlite:///database.db

# Flask-Mail Server Configurations (e.g. Gmail SMTP server)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USE_SSL=False
MAIL_USERNAME=your_smtp_username@gmail.com
MAIL_PASSWORD=your_smtp_app_password
MAIL_DEFAULT_SENDER=your_smtp_username@gmail.com

# Session Security Configuration (True in production under HTTPS)
SESSION_COOKIE_SECURE=False
